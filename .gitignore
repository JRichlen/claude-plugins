# Local staging produced when *running* the workflow. These are root-anchored
# (leading slash) so they don't accidentally match the skills/graveyard/ source
# directory — an unanchored `graveyard/` matches at ANY depth and would ignore
# the skill itself.
/graveyard/
/mirrors/
/delete-originals.sh
/summary.tsv
*.bundle
.DS_Store

# Eval artifacts. Secrets and generated output must never be committed.
node_modules/
.env
.env.*
# promptfoo writes its run cache and HTML output here.
plugins/graveyard/evals/promptfoo/output/
.promptfoo/
promptfoo-errors.log
# pier stages a fresh copy of the live skill scripts into each task's build
# context at run time (see plugins/graveyard/evals/pier/run.sh) — it's generated, not source.
plugins/graveyard/evals/pier/tasks/*/environment/skill/
# pier run logs / local results. run.sh writes per-agent job dirs under jobs/.
plugins/graveyard/evals/pier/.pier/
plugins/graveyard/evals/pier/runs/
plugins/graveyard/evals/pier/jobs/
